PORT=3001
NODE_ENV=development
API_PREFIX=/api/v1
MONGODB_URI=mongodb://127.0.0.1:27017/chocoriches
JWT_SECRET=change-this-for-production
JWT_EXPIRE=7d
COOKIE_EXPIRE=7
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
